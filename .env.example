# ── Clés API des LLMs à tester ─────────────────────────────────────────────
# Seuls les LLMs dont la clé est renseignée seront interrogés.
# Tu peux n'en mettre qu'une seule, ou toutes.

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REMPLACE

# OpenAI (GPT-4o) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REMPLACE

# Google (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AI-REMPLACE

# Perplexity (Sonar) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-REMPLACE
