# ── 2 clés seulement ──────────────────────────────────────────────────────────

# 1. Anthropic — pour analyser les réponses (mesurer si RG est citée, tonalité, score)
#    Obtenir : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REMPLACE

# 2. OpenRouter — pour interroger TOUS les autres LLMs (GPT-4o, Gemini, Perplexity, Mistral...)
#    Un seul compte donne accès à +100 modèles.
#    Obtenir : https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REMPLACE
